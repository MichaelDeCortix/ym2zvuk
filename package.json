{
  "name": "ym2zvuk",
  "version": "0.2.0",
  "type": "module",
  "description": "CLI для миграции треков, лайков и плейлистов из Яндекс Музыки в Звук / SberZvuk.",
  "keywords": [
    "yandex-music",
    "zvuk",
    "sberzvuk",
    "migration",
    "music-migration",
    "playlist-migration",
    "track-migration",
    "cli",
    "playwright"
  ],
  "bin": {
    "ym2zvuk": "./src/cli.js"
  },
  "scripts": {
    "init": "node ./src/cli.js init",
    "export": "node ./src/cli.js export",
    "match": "node ./src/cli.js match",
    "probe": "node ./src/cli.js probe",
    "import": "node ./src/cli.js import",
    "verify": "node ./src/cli.js verify",
    "migrate": "node ./src/cli.js migrate",
    "reset": "node ./src/cli.js reset",
    "test": "node --test"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "axios-cookiejar-support": "^6.0.4",
    "playwright": "^1.55.0",
    "tough-cookie": "^5.1.2"
  }
}
